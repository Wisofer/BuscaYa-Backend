@{
    Layout = null;
    var email = (string?)ViewBag.Email ?? string.Empty;
    var token = (string?)ViewBag.Token ?? string.Empty;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Restablecer contraseña - BuscaYa</title>
    <style>
        :root {
            --bg: #f8fafc;
            --card: #ffffff;
            --text: #0f172a;
            --soft: #475569;
            --primary: #ea580c;
            --primary-2: #f97316;
            --border: #e2e8f0;
            --ok-bg: #ecfdf3;
            --ok-text: #166534;
            --err-bg: #fef2f2;
            --err-text: #991b1b;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, sans-serif;
            background: linear-gradient(180deg, #fff7ed 0%, var(--bg) 55%);
            color: var(--text);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .card {
            width: 100%;
            max-width: 460px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: 0 14px 34px rgba(15, 23, 42, .1);
            overflow: hidden;
        }
        .header {
            text-align: center;
            padding: 24px 22px 12px;
            background: #fff7ed;
        }
        .brand {
            margin: 0;
            font-size: 28px;
            font-weight: 800;
        }
        .brand .a { color: #111827; }
        .brand .b { color: var(--primary); }
        h1 { margin: 8px 0 4px; font-size: 22px; }
        .subtitle { margin: 0; color: var(--soft); font-size: 14px; line-height: 1.5; }
        .content { padding: 20px 22px 22px; }
        .helper { margin: 0 0 15px; color: var(--soft); font-size: 14px; line-height: 1.5; }
        .field { margin-bottom: 14px; }
        label { display: block; margin-bottom: 6px; font-size: 13px; font-weight: 700; }
        input {
            width: 100%;
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 11px 12px;
            font-size: 14px;
            outline: none;
        }
        input:focus {
            border-color: var(--primary-2);
            box-shadow: 0 0 0 3px rgba(249, 115, 22, .15);
        }
        .submit {
            width: 100%;
            margin-top: 6px;
            border: 0;
            border-radius: 10px;
            padding: 12px;
            color: #fff;
            background: linear-gradient(135deg, var(--primary-2), var(--primary));
            cursor: pointer;
            font-size: 15px;
            font-weight: 700;
        }
        .submit:disabled { opacity: .75; cursor: not-allowed; }
        .msg {
            margin-top: 14px;
            padding: 11px 12px;
            border-radius: 10px;
            font-size: 14px;
            display: none;
        }
        .ok { background: var(--ok-bg); color: var(--ok-text); border: 1px solid #bbf7d0; }
        .err { background: var(--err-bg); color: var(--err-text); border: 1px solid #fecaca; }
        .success { display: none; margin-top: 8px; color: #166534; font-size: 14px; text-align: center; }
    </style>
</head>
<body>
    <div class="card">
        <div class="header">
            <p class="brand"><span class="a">Busca</span><span class="b">Ya</span></p>
            <h1>Restablecer contraseña</h1>
            <p class="subtitle">Crea una nueva clave para acceder nuevamente a tu cuenta.</p>
        </div>
        <div class="content">
            <p class="helper">Tu enlace de recuperación expira en 30 minutos.</p>
            <form id="resetForm">
                <div class="field">
                    <label for="password">Nueva contraseña</label>
                    <input id="password" type="password" minlength="6" required />
                </div>
                <div class="field">
                    <label for="confirm">Confirmar contraseña</label>
                    <input id="confirm" type="password" minlength="6" required />
                </div>
                <button class="submit" id="submitBtn" type="submit">Actualizar contraseña</button>
                <div id="msg" class="msg"></div>
                <div id="success" class="success">Contraseña actualizada correctamente. Ya puedes iniciar sesión.</div>
            </form>
        </div>
    </div>

    <script>
        const form = document.getElementById('resetForm');
        const msg = document.getElementById('msg');
        const success = document.getElementById('success');
        const submitBtn = document.getElementById('submitBtn');
        const query = new URLSearchParams(window.location.search);
        const email = '@email' || query.get('email') || '';
        const token = '@token' || query.get('token') || '';

        function showMessage(text, isError) {
            msg.className = 'msg ' + (isError ? 'err' : 'ok');
            msg.textContent = text;
            msg.style.display = 'block';
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            msg.style.display = 'none';
            success.style.display = 'none';
            const password = document.getElementById('password').value;
            const confirm = document.getElementById('confirm').value;

            if (!email || !token) {
                showMessage('El enlace de recuperación no es válido. Solicita uno nuevo.', true);
                return;
            }
            if (password !== confirm) {
                showMessage('Las contraseñas no coinciden.', true);
                return;
            }

            submitBtn.disabled = true;
            submitBtn.textContent = 'Procesando...';
            try {
                const resp = await fetch('/api/auth/reset-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, token, newPassword: password })
                });
                const data = await resp.json();
                if (!resp.ok) {
                    showMessage(data.error || data.message || 'No se pudo restablecer la contraseña.', true);
                    return;
                }
                showMessage(data.message || 'Contraseña actualizada correctamente.', false);
                success.style.display = 'block';
                form.reset();
            } catch {
                showMessage('Error de red. Intenta nuevamente.', true);
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Actualizar contraseña';
            }
        });
    </script>
</body>
</html>
