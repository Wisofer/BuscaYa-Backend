@{
    Layout = null;
    var email = (string?)ViewBag.Email ?? string.Empty;
    var token = (string?)ViewBag.Token ?? string.Empty;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Restablecer contraseña - BuscaYa</title>
    <style>
        :root {
            --bg: #f3f8ff;
            --card: #ffffff;
            --text: #10223f;
            --soft: #4c5f7c;
            --primary: #0b57d0;
            --primary-2: #2f8dff;
            --border: #d8e6ff;
            --ok-bg: #edf4ff;
            --ok-text: #0b57d0;
            --err-bg: #fef2f2;
            --err-text: #991b1b;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, sans-serif;
            background: linear-gradient(180deg, #ffffff 0%, var(--bg) 60%);
            color: var(--text);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .card {
            width: 100%;
            max-width: 460px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: 0 16px 38px rgba(27, 74, 152, .12);
            overflow: hidden;
        }
        .header {
            text-align: center;
            padding: 22px 22px 12px;
            background: linear-gradient(180deg, #ffffff 0%, #f3f8ff 100%);
        }
        .logo {
            width: 120px;
            height: auto;
            margin: 0 auto 8px;
            display: block;
        }
        h1 { margin: 8px 0 4px; font-size: 22px; }
        .subtitle { margin: 0; color: var(--soft); font-size: 14px; line-height: 1.5; }
        .content { padding: 20px 22px 22px; }
        .helper { margin: 0 0 15px; color: var(--soft); font-size: 14px; line-height: 1.5; }
        .field { margin-bottom: 14px; }
        label { display: block; margin-bottom: 6px; font-size: 13px; font-weight: 700; }
        .input-wrap {
            position: relative;
        }
        input {
            width: 100%;
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 11px 44px 11px 12px;
            font-size: 14px;
            outline: none;
        }
        input:focus {
            border-color: var(--primary-2);
            box-shadow: 0 0 0 3px rgba(47, 141, 255, .15);
        }
        .toggle-eye {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            border: 0;
            background: transparent;
            color: #6b85ad;
            cursor: pointer;
            padding: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .toggle-eye svg {
            width: 18px;
            height: 18px;
        }
        .submit {
            width: 100%;
            margin-top: 6px;
            border: 0;
            border-radius: 10px;
            padding: 12px;
            color: #fff;
            background: linear-gradient(135deg, var(--primary-2), var(--primary));
            cursor: pointer;
            font-size: 15px;
            font-weight: 700;
        }
        .submit:disabled { opacity: .75; cursor: not-allowed; }
        .msg {
            margin-top: 14px;
            padding: 11px 12px;
            border-radius: 10px;
            font-size: 14px;
            display: none;
        }
        .ok { background: var(--ok-bg); color: var(--ok-text); border: 1px solid #cfe2ff; }
        .err { background: var(--err-bg); color: var(--err-text); border: 1px solid #fecaca; }
        .success {
            display: none;
            margin-top: 10px;
            padding: 10px 12px;
            background: #edf4ff;
            border: 1px solid #cfe2ff;
            border-radius: 10px;
            color: #0b57d0;
            font-size: 14px;
            text-align: center;
            line-height: 1.45;
        }
        .success-check {
            width: 56px;
            height: 56px;
            margin: 0 auto 10px;
            border-radius: 50%;
            background: linear-gradient(180deg, #2f8dff, #0b57d0);
            color: #ffffff;
            display: grid;
            place-items: center;
            font-size: 30px;
            font-weight: 700;
            box-shadow: 0 10px 20px rgba(11, 87, 208, .22);
        }
        .success-title {
            margin: 0 0 6px;
            font-size: 18px;
            font-weight: 800;
            color: #0b57d0;
        }
        .success-text {
            margin: 0;
            font-size: 14px;
            color: #2a4f87;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="header">
            <img class="logo" src="/images/buscayasplash.png" alt="Logo BuscaYa" />
            <h1>Restablecer contraseña</h1>
            <p class="subtitle">Crea una nueva clave para acceder nuevamente a tu cuenta.</p>
        </div>
        <div class="content">
            <p class="helper">Tu enlace de recuperación expira en 30 minutos.</p>
            <form id="resetForm">
                <div class="field">
                    <label for="password">Nueva contraseña</label>
                    <div class="input-wrap">
                        <input id="password" type="password" minlength="6" required />
                        <button class="toggle-eye" type="button" data-target="password" aria-label="Mostrar contraseña"></button>
                    </div>
                </div>
                <div class="field">
                    <label for="confirm">Confirmar contraseña</label>
                    <div class="input-wrap">
                        <input id="confirm" type="password" minlength="6" required />
                        <button class="toggle-eye" type="button" data-target="confirm" aria-label="Mostrar confirmación"></button>
                    </div>
                </div>
                <button class="submit" id="submitBtn" type="submit">Actualizar contraseña</button>
                <div id="msg" class="msg"></div>
            </form>
            <div id="success" class="success">
                <div class="success-check">✓</div>
                <h2 class="success-title">Contraseña actualizada</h2>
                <p class="success-text">Tu contraseña ha cambiado, regresa a la app y vuelve a ingresar.</p>
            </div>
        </div>
    </div>

    <script>
        const form = document.getElementById('resetForm');
        const msg = document.getElementById('msg');
        const success = document.getElementById('success');
        const submitBtn = document.getElementById('submitBtn');
        const query = new URLSearchParams(window.location.search);
        const email = '@email' || query.get('email') || '';
        const token = '@token' || query.get('token') || '';
        const eyeOpenIcon = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
        const eyeClosedIcon = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 3 18 18"></path><path d="M10.58 10.58A2 2 0 0 0 13.42 13.42"></path><path d="M9.36 5.37A9.76 9.76 0 0 1 12 5c6.5 0 10 7 10 7a17.5 17.5 0 0 1-2.14 2.94"></path><path d="M6.61 6.61C4.62 8.06 3.36 10.06 2 12c0 0 3.5 7 10 7a9.74 9.74 0 0 0 5.39-1.61"></path></svg>';

        function showMessage(text, isError) {
            msg.className = 'msg ' + (isError ? 'err' : 'ok');
            msg.textContent = text;
            msg.style.display = 'block';
        }

        document.querySelectorAll('.toggle-eye').forEach((btn) => {
            btn.innerHTML = eyeOpenIcon;
            btn.addEventListener('click', () => {
                const input = document.getElementById(btn.dataset.target);
                const shouldShow = input.type === 'password';
                input.type = shouldShow ? 'text' : 'password';
                btn.innerHTML = shouldShow ? eyeClosedIcon : eyeOpenIcon;
            });
        });

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            msg.style.display = 'none';
            success.style.display = 'none';
            const password = document.getElementById('password').value;
            const confirm = document.getElementById('confirm').value;

            if (!email || !token) {
                showMessage('El enlace de recuperación no es válido. Solicita uno nuevo.', true);
                return;
            }
            if (password !== confirm) {
                showMessage('Las contraseñas no coinciden.', true);
                return;
            }

            submitBtn.disabled = true;
            submitBtn.textContent = 'Procesando...';
            try {
                const resp = await fetch('/api/auth/reset-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, token, newPassword: password })
                });
                const data = await resp.json();
                if (!resp.ok) {
                    showMessage(data.error || data.message || 'No se pudo restablecer la contraseña.', true);
                    return;
                }
                msg.style.display = 'none';
                form.style.display = 'none';
                success.style.display = 'block';
            } catch {
                showMessage('Error de red. Intenta nuevamente.', true);
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Actualizar contraseña';
            }
        });
    </script>
</body>
</html>
