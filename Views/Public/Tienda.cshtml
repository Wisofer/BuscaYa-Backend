@using BuscaYa.Models.DTOs.Responses
@{
    var tienda = ViewData["Tienda"] as TiendaResponse;
    var deepLink = ViewData["DeepLink"] as string ?? "";
    var appleAppId = ViewData["AppleAppId"] as string;

    ViewData["Title"] = tienda?.Nombre ?? "Tienda";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@tienda?.Nombre - Catálogo Digital | BuscaYa</title>

    <!-- Meta tags para compartir en redes sociales -->
    <meta property="og:title" content="@tienda?.Nombre - Catálogo Digital en BuscaYa" />
    <meta property="og:description" content="@(tienda?.Descripcion ?? "Explora nuestro catálogo en línea y haz tus pedidos directamente por WhatsApp.")" />
    @if (!string.IsNullOrEmpty(tienda?.FotoUrl ?? tienda?.LogoUrl))
    {
        <meta property="og:image" content="@(tienda?.FotoUrl ?? tienda?.LogoUrl)" />
    }
    <meta property="og:type" content="business.business" />
    @if (!string.IsNullOrEmpty(appleAppId))
    {
        <meta name="apple-itunes-app" content="app-id=@appleAppId" />
    }

    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <!-- Alpine.js & Tailwind CSS -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f0f7ff',
                            100: '#e0effe',
                            500: '#1d4ed8', // Azul real premium
                            600: '#1e40af', // Azul oscuro
                            700: '#1d3557',
                            900: '#0f172a',
                        },
                    }
                }
            }
        }
    </script>

    <style>
        [x-cloak] { display: none !important; }
        
        body {
            background-color: #f8fafc;
            color: #0f172a;
        }

        /* Ocultar barra de scroll nativa */
        .scrollbar-none::-webkit-scrollbar {
            display: none;
        }
        .scrollbar-none {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        /* Grid Background Pattern */
        .grid-bg {
            background-image: radial-gradient(#e2e8f0 1.5px, transparent 1.5px);
            background-size: 24px 24px;
        }
    </style>
</head>
<body class="antialiased selection:bg-brand-500 selection:text-white min-h-screen flex flex-col justify-between" 
      x-data="catalogoStore(tiendaConfig)">

    @if (tienda == null)
    {
        <!-- Vista Tienda No Encontrada -->
        <div class="min-h-screen flex items-center justify-center px-4 bg-slate-50">
            <div class="max-w-md w-full text-center bg-white border border-slate-100 p-8 rounded-3xl shadow-xl">
                <div class="inline-flex p-4 bg-red-50 text-red-500 rounded-2xl mb-6">
                    <i data-lucide="store" class="w-12 h-12"></i>
                </div>
                <h2 class="text-2xl font-bold text-slate-900 mb-2">Comercio no encontrado</h2>
                <p class="text-slate-500 mb-6">El comercio que intentas buscar no está disponible o la dirección es incorrecta.</p>
                <a href="https://buscaya.encuentrame.org" class="inline-flex items-center gap-2 px-6 py-3 bg-brand-500 hover:bg-brand-600 active:scale-95 transition-all text-white font-semibold rounded-xl">
                    <i data-lucide="arrow-left" class="w-5 h-5"></i>
                    Ir a BuscaYa
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Banner Inteligente de Descarga App para Móviles (Estilo Glassmorphism Apple) -->
        <div x-data="{ 
                showBanner: false,
                os: 'unknown',
                dismiss() {
                    this.showBanner = false;
                    sessionStorage.setItem('buscaya_hide_app_banner', 'true');
                },
                init() {
                    // Detectar OS
                    const ua = navigator.userAgent || navigator.vendor || window.opera;
                    if (/android/i.test(ua)) {
                        this.os = 'android';
                    } else if (/iPad|iPhone|iPod/.test(ua) && !window.MSStream) {
                        this.os = 'ios';
                    }

                    // Mostrar banner si no ha sido descartado
                    if (sessionStorage.getItem('buscaya_hide_app_banner') !== 'true') {
                        setTimeout(() => {
                            this.showBanner = true;
                        }, 1200);
                    }
                },
                getDownloadUrl() {
                    if (this.os === 'android') {
                        return 'https://play.google.com/store/apps/details?id=com.buscaya.app';
                    }
                    if (this.os === 'ios') {
                        return 'https://apps.apple.com/app/id6762116740';
                    }
                    return '/descargar';
                }
             }"
             x-show="showBanner"
             x-transition:enter="transition ease-out duration-500 transform"
             x-transition:enter-start="translate-y-full opacity-0"
             x-transition:enter-end="translate-y-0 opacity-100"
             x-transition:leave="transition ease-in duration-300 transform"
             x-transition:leave-start="translate-y-0 opacity-100"
             x-transition:leave-end="translate-y-full opacity-0"
             class="fixed bottom-4 left-4 right-4 z-[100] md:hidden pointer-events-auto"
             x-cloak>
            
            <div class="relative overflow-hidden rounded-3xl border border-white/40 bg-white/75 backdrop-blur-2xl p-5 shadow-2xl shadow-slate-900/10 flex items-center gap-4">
                <!-- Efecto de brillo de cristal -->
                <div class="absolute inset-0 bg-gradient-to-tr from-white/10 via-white/20 to-white/5 pointer-events-none"></div>
                
                <!-- Botón Cerrar (X) -->
                <button @@click="dismiss()" class="absolute top-3 right-3 p-1 rounded-full text-slate-400 hover:text-slate-600 hover:bg-slate-950/5 transition">
                    <i data-lucide="x" class="w-4 h-4"></i>
                </button>

                <!-- Icono de App Premium -->
                <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-slate-900 to-slate-950 flex items-center justify-center shadow-md border border-white/25 flex-shrink-0">
                    <img src="/images/app_launcher_icon.png" alt="BuscaYa Icon" class="w-8 h-8 object-contain rounded-lg" />
                </div>

                <!-- Textos -->
                <div class="flex-grow pr-5">
                    <h4 class="text-xs font-extrabold text-slate-900 tracking-tight flex items-center gap-1">
                        Abre en la App BuscaYa
                        <span class="inline-flex px-1.5 py-0.5 rounded-full text-[8px] font-black bg-brand-50 text-brand-600 border border-brand-100 uppercase tracking-wider">Gratis</span>
                    </h4>
                    <p class="text-[10px] text-slate-500 leading-tight mt-0.5">Una experiencia de compra más rápida y exclusiva para ti.</p>
                    
                    <div class="flex items-center gap-2 mt-2">
                        <!-- Botón Descargar / Instalar -->
                        <a :href="getDownloadUrl()" target="_blank" class="inline-flex items-center gap-1 px-3 py-1.5 bg-slate-900 hover:bg-slate-800 active:scale-95 transition-all text-white font-extrabold rounded-xl text-[10px] shadow-sm">
                            <span x-text="os === 'unknown' ? 'Descargar App' : 'Instalar Gratis'"></span>
                            <i data-lucide="arrow-right" class="w-3 h-3"></i>
                        </a>
                        
                        @if (!string.IsNullOrEmpty(deepLink))
                        {
                            <a href="@deepLink" class="inline-flex items-center gap-1 px-3 py-1.5 bg-brand-50 hover:bg-brand-100 text-brand-600 font-extrabold rounded-xl text-[10px] border border-brand-100/50 transition">
                                Abrir en App
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Top Floating Glass Navbar (Apple/Tesla Premium Style with Scroll Transition) -->
        <header class="fixed top-0 left-0 w-full z-50 px-4 pt-4 pb-2 pointer-events-none transition-all duration-300"
                x-data="{ scrolled: false }"
                @@scroll.window="scrolled = (window.pageYOffset > 50)">
            <div class="pointer-events-auto mx-auto max-w-6xl h-16 rounded-full flex items-center justify-between px-6 transition-all duration-500"
                 :class="scrolled 
                    ? 'border border-slate-200/65 bg-white/80 backdrop-blur-xl shadow-xl shadow-slate-900/5' 
                    : 'border border-transparent bg-transparent shadow-none'">
                <!-- Store branding (No mention of BuscaYa in top navbar) -->
                <div class="flex items-center gap-3 transition-all duration-300 transform"
                     :class="scrolled ? 'opacity-100 translate-x-0' : 'opacity-0 -translate-x-4 pointer-events-none md:opacity-100 md:translate-x-0 md:pointer-events-auto'">
                    @if (!string.IsNullOrWhiteSpace(tienda.LogoUrl))
                    {
                        <img src="@tienda.LogoUrl" alt="Logo de @tienda.Nombre" class="w-9 h-9 rounded-full object-cover ring-2 ring-slate-100/50 shadow-sm transition hover:scale-105 duration-300" onerror="this.outerHTML='<div class=\'w-9 h-9 rounded-full bg-brand-500 flex items-center justify-center ring-2 ring-slate-100/50 shadow-sm text-white font-black text-xs\'>@tienda.Nombre.Substring(0, 1).ToUpper()</div>'" />
                    }
                    else
                    {
                        <div class="w-9 h-9 rounded-full bg-brand-500 flex items-center justify-center ring-2 ring-slate-100/50 shadow-sm text-white font-black text-xs">
                            @tienda.Nombre.Substring(0, 1).ToUpper()
                        </div>
                    }
                    <div class="flex flex-col">
                        <span class="font-extrabold tracking-tight text-xs sm:text-sm leading-tight flex items-center gap-1 transition-colors duration-300"
                              :class="scrolled ? 'text-slate-900' : 'text-white'">
                            @tienda.Nombre
                        </span>
                        <span class="text-[9px] font-bold tracking-wider uppercase transition-colors duration-300"
                              :class="scrolled ? 'text-slate-400' : 'text-white/60'">Exclusive Merchant</span>
                    </div>
                </div>

                <!-- Navigation Links Premium (Apple/Tesla Minimal Style) -->
                <nav class="hidden md:flex items-center gap-1.5 text-[11px] font-bold uppercase tracking-wider transition-colors duration-300"
                     :class="scrolled ? 'text-slate-500' : 'text-white/85'">
                    <a href="#catalogo" @@click.prevent="document.getElementById('catalogo').scrollIntoView({behavior: 'smooth'})" class="flex items-center gap-1.5 px-4 py-2 rounded-full transition duration-300"
                       :class="scrolled ? 'text-slate-900 bg-slate-950/5 hover:bg-slate-950/10' : 'text-white bg-white/10 hover:bg-white/20'">
                        Catálogo
                    </a>
                    <a href="#contacto" @@click.prevent="window.scrollTo({top: document.body.scrollHeight, behavior: 'smooth'})" class="flex items-center gap-1.5 px-4 py-2 rounded-full transition duration-300"
                       :class="scrolled ? 'hover:bg-slate-950/5 hover:text-slate-950' : 'hover:bg-white/10 hover:text-white'">
                        Contacto
                    </a>
                    <a href="#nosotros" @@click.prevent="window.scrollTo({top: document.body.scrollHeight, behavior: 'smooth'})" class="flex items-center gap-1.5 px-4 py-2 rounded-full transition duration-300"
                       :class="scrolled ? 'hover:bg-slate-950/5 hover:text-slate-950' : 'hover:bg-white/10 hover:text-white'">
                        Nosotros
                    </a>
                </nav>

                <!-- Actions -->
                <div class="flex items-center gap-3">
                    <!-- Botón Carrito flotante en Navbar -->
                    <button class="relative p-2.5 rounded-full transition active:scale-95 duration-200"
                            :class="scrolled ? 'text-slate-800 hover:bg-slate-950/5' : 'text-white hover:bg-white/10'"
                            @@click="cartOpen = true">
                        <i data-lucide="shopping-basket" class="w-5 h-5"></i>
                        <span class="absolute top-0.5 right-0.5 bg-brand-500 text-white font-extrabold text-[9px] w-5 h-5 rounded-full flex items-center justify-center shadow"
                              x-show="cartTotalCount() > 0"
                              x-text="cartTotalCount()"></span>
                    </button>

                    <a href="/descargar" class="hidden sm:inline-flex items-center gap-1.5 px-5 py-2.5 font-extrabold rounded-full text-xs active:scale-95 transition-all duration-300"
                       :class="scrolled 
                          ? 'bg-brand-500 text-white hover:bg-brand-600 shadow-md shadow-brand-500/20' 
                          : 'bg-white text-slate-900 hover:bg-slate-100 shadow-lg shadow-white/10'">
                        Descargar App
                        <i data-lucide="arrow-right" class="w-3.5 h-3.5"></i>
                    </a>
                </div>
            </div>
        </header>

        <!-- Main Wrapper -->
        <main class="flex-grow">
            <!-- ================= VISTA DE ESCRITORIO (DECORADO ORIGINAL DIRECTO EN BANNER) ================= -->
            <div class="hidden md:block relative h-80 md:h-[400px] w-full overflow-hidden bg-slate-900 grid-bg">
                <div class="absolute inset-0 bg-gradient-to-b from-slate-950/20 via-slate-950/40 to-slate-950/80 z-10 pointer-events-none"></div>
                @if (!string.IsNullOrWhiteSpace(tienda.FotoUrl))
                {
                    <img id="banner-desktop-img" src="@tienda.FotoUrl" alt="@tienda.Nombre" class="w-full h-full object-cover opacity-90 scale-100" onerror="this.style.display='none'; document.getElementById('banner-desktop-fallback').style.display='block';" />
                    <div id="banner-desktop-fallback" style="display: none;" class="w-full h-full bg-gradient-to-r from-brand-800 via-brand-900 to-slate-900 opacity-90">
                        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiPgo8cmVjdCB3aWR0aD0iOCIgaGVpZ2h0PSI4IiBmaWxsPSIjZmZmIiBmaWxsLW9wYWNpdHk9IjAuMDUiLz4KPC9zdmc+')] opacity-50 mix-blend-overlay"></div>
                    </div>
                }
                else
                {
                    <div class="w-full h-full bg-gradient-to-r from-brand-800 via-brand-900 to-slate-900 opacity-90">
                        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiPgo8cmVjdCB3aWR0aD0iOCIgaGVpZ2h0PSI4IiBmaWxsPSIjZmZmIiBmaWxsLW9wYWNpdHk9IjAuMDUiLz4KPC9zdmc+')] opacity-50 mix-blend-overlay"></div>
                    </div>
                }

                <!-- Contenido solapado directamente sobre el Banner para look Premium (Estilo Web Original) -->
                <div class="absolute inset-0 z-20 flex items-end">
                    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pb-10 md:pb-12">
                        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
                            <div class="flex flex-col sm:flex-row items-start sm:items-end gap-4 sm:gap-6">
                                <!-- Logo Circular Overlapping -->
                                <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-full border-4 border-white/10 overflow-hidden bg-white/95 backdrop-blur shadow-2xl flex-shrink-0 flex items-center justify-center">
                                    @if (!string.IsNullOrWhiteSpace(tienda.LogoUrl))
                                    {
                                        <img src="@tienda.LogoUrl" alt="Logo de @tienda.Nombre" class="w-full h-full object-cover" onerror="this.outerHTML='<span class=\'text-3xl sm:text-4xl font-black text-brand-500\'>@tienda.Nombre.Substring(0, 1).ToUpper()</span>'" />
                                    }
                                    else
                                    {
                                        <span class="text-3xl sm:text-4xl font-black text-brand-500">@tienda.Nombre.Substring(0, 1).ToUpper()</span>
                                    }
                                </div>

                                <!-- Texto Hero -->
                                <div class="space-y-2 text-white">
                                    <div class="flex flex-wrap items-center gap-2">
                                        <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight flex items-center gap-2 text-white">
                                            @tienda.Nombre
                                        </h1>
                                        @if (tienda.EstaAbierta)
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold bg-emerald-500/20 text-emerald-300 border border-emerald-500/30 backdrop-blur-md">
                                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                                                Abierto
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold bg-red-500/20 text-red-300 border border-red-500/30 backdrop-blur-md">
                                                <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>
                                                Cerrado
                                            </span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(tienda.Descripcion))
                                    {
                                        <p class="text-slate-200 text-sm sm:text-base max-w-xl font-medium leading-relaxed opacity-90">@tienda.Descripcion</p>
                                    }
                                    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs sm:text-sm text-slate-350 pt-1">
                                        <div class="flex items-center gap-1.5">
                                            <i data-lucide="map-pin" class="w-4 h-4 text-slate-400"></i>
                                            <span>@tienda.Direccion</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Botones de Acción sobre Banner -->
                            <div class="flex gap-3 w-full md:w-auto self-stretch md:self-auto flex-wrap sm:flex-nowrap">
                                @if (!string.IsNullOrEmpty(tienda.WhatsApp))
                                {
                                    var whatsappLink = BuscaYa.Utils.WhatsAppHelper.GenerarLinkSimple(tienda.WhatsApp);
                                    <a href="@whatsappLink" target="_blank" class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2 px-6 py-3 bg-emerald-600 hover:bg-emerald-500 active:scale-95 transition-all text-white font-bold rounded-2xl shadow-lg shadow-emerald-900/30 text-sm">
                                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
                                        </svg>
                                        WhatsApp
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(tienda.Telefono))
                                {
                                    <a href="tel:@tienda.Telefono" class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2 px-6 py-3 bg-white/10 hover:bg-white/20 backdrop-blur active:scale-95 transition-all text-white font-bold rounded-2xl border border-white/20 text-sm">
                                        <i data-lucide="phone" class="w-5 h-5"></i>
                                        Llamar
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ================= VISTA DE MÓVIL (block md:hidden) ================= -->
            <div class="block md:hidden relative h-44 w-full overflow-hidden bg-slate-900 grid-bg">
                <div class="absolute inset-0 bg-gradient-to-b from-slate-950/20 via-slate-950/40 to-slate-950/70 z-10 pointer-events-none"></div>
                @if (!string.IsNullOrWhiteSpace(tienda.FotoUrl))
                {
                    <img id="banner-mobile-img" src="@tienda.FotoUrl" alt="@tienda.Nombre" class="w-full h-full object-cover opacity-85 scale-100" onerror="this.style.display='none'; document.getElementById('banner-mobile-fallback').style.display='block';" />
                    <div id="banner-mobile-fallback" style="display: none;" class="w-full h-full bg-gradient-to-r from-brand-800 via-brand-900 to-slate-900 opacity-90">
                        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiPgo8cmVjdCB3aWR0aD0iOCIgaGVpZ2h0PSI4IiBmaWxsPSIjZmZmIiBmaWxsLW9wYWNpdHk9IjAuMDUiLz4KPC9zdmc+')] opacity-50 mix-blend-overlay"></div>
                    </div>
                }
                else
                {
                    <div class="w-full h-full bg-gradient-to-r from-brand-800 via-brand-900 to-slate-900 opacity-90">
                        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4IiBoZWlnaHQ9IjgiPgo8cmVjdCB3aWR0aD0iOCIgaGVpZ2h0PSI4IiBmaWxsPSIjZmZmIiBmaWxsLW9wYWNpdHk9IjAuMDUiLz4KPC9zdmc+')] opacity-50 mix-blend-overlay"></div>
                    </div>
                }
            </div>

            <!-- Información del Comercio Móvil (Flujo Natural con Logo Solapado) -->
            <div class="block md:hidden relative max-w-7xl mx-auto px-4 z-20 -mt-16 pb-4">
                <div class="bg-white/85 backdrop-blur-xl border border-slate-200/60 rounded-3xl p-6 shadow-xl shadow-slate-100/50 flex flex-col items-center gap-5 text-center">
                    
                    <!-- Logo Circular Solapado -->
                    <div class="w-24 h-24 rounded-full border-4 border-white overflow-hidden bg-white shadow-lg flex-shrink-0 flex items-center justify-center">
                        @if (!string.IsNullOrWhiteSpace(tienda.LogoUrl))
                        {
                            <img src="@tienda.LogoUrl" alt="Logo de @tienda.Nombre" class="w-full h-full object-cover" onerror="this.outerHTML='<span class=\'text-3xl font-black text-brand-500\'>@tienda.Nombre.Substring(0, 1).ToUpper()</span>'" />
                        }
                        else
                        {
                            <span class="text-3xl font-black text-brand-500">@tienda.Nombre.Substring(0, 1).ToUpper()</span>
                        }
                    </div>

                    <!-- Textos de la Tienda -->
                    <div class="space-y-2 flex-grow w-full">
                        <div class="flex flex-col items-center gap-2">
                            <h1 class="text-2xl font-extrabold tracking-tight flex items-center gap-2 text-slate-900">
                                @tienda.Nombre
                            </h1>
                            <div class="inline-flex">
                                @if (tienda.EstaAbierta)
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-emerald-500/10 text-emerald-600 border border-emerald-500/20">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                                        Abierto
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-red-500/10 text-red-650 border border-red-500/20">
                                        <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                                        Cerrado
                                    </span>
                                }
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(tienda.Descripcion))
                        {
                            <p class="text-slate-500 text-sm font-medium leading-relaxed">@tienda.Descripcion</p>
                        }
                        <div class="flex items-center justify-center gap-1.5 text-xs text-slate-400">
                            <i data-lucide="map-pin" class="w-4 h-4 text-slate-400"></i>
                            <span>@tienda.Direccion</span>
                        </div>
                    </div>

                    <!-- Botones de Acción (WhatsApp / Llamar) -->
                    <div class="grid grid-cols-2 gap-3 w-full mt-2">
                        @if (!string.IsNullOrEmpty(tienda.WhatsApp))
                        {
                            var whatsappLink = BuscaYa.Utils.WhatsAppHelper.GenerarLinkSimple(tienda.WhatsApp);
                            <a href="@whatsappLink" target="_blank" 
                               class="flex items-center justify-center gap-2 px-4 py-3 bg-[#25D366] hover:bg-[#20ba59] active:scale-[0.98] transition-all text-white font-extrabold rounded-2xl shadow-lg shadow-emerald-500/10 text-xs">
                                <svg class="w-5 h-5 fill-current" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
                                </svg>
                                WhatsApp
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(tienda.Telefono))
                        {
                            <a href="tel:@tienda.Telefono" 
                               class="flex items-center justify-center gap-2 px-4 py-3 bg-brand-500 hover:bg-brand-600 active:scale-[0.98] transition-all text-white font-extrabold rounded-2xl shadow-lg shadow-brand-500/20 text-xs">
                                <i data-lucide="phone" class="w-5 h-5 text-white"></i>
                                Llamar
                            </a>
                        }
                    </div>
                </div>
            </div>

            <!-- Contenido del Catálogo -->
            <div id="catalogo" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
                <!-- Buscador e input -->
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8">
                    <div class="relative w-full md:max-w-md">
                        <i data-lucide="search" class="w-5 h-5 text-slate-400 absolute left-4 top-1/2 -translate-y-1/2"></i>
                        <input type="text" 
                               placeholder="Buscar en el catálogo..." 
                               x-model="searchQuery"
                               class="w-full pl-12 pr-11 py-3 bg-slate-50 border border-slate-100 focus:bg-white focus:border-brand-500 focus:ring-4 focus:ring-brand-100 rounded-2xl text-slate-900 placeholder-slate-400 outline-none transition-all text-sm font-medium" />
                        <!-- Botón Limpiar (X) -->
                        <button x-show="searchQuery.length > 0" 
                                @@click="searchQuery = ''" 
                                class="absolute right-3.5 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-650 transition-colors p-1.5 rounded-full hover:bg-slate-200/50 flex items-center justify-center"
                                x-cloak>
                            <i data-lucide="x" class="w-4 h-4"></i>
                        </button>
                    </div>

                    <!-- Filtro Categorías Pills -->
                    <div class="flex items-center gap-2 overflow-x-auto scrollbar-none py-1.5">
                        <button class="px-6 py-2.5 rounded-full text-xs font-black whitespace-nowrap transition-all duration-300 flex items-center gap-1.5"
                                :class="categoriaSeleccionada === 'all' 
                                    ? 'bg-slate-900 text-white shadow-xl shadow-slate-900/20 scale-100' 
                                    : 'bg-white border border-slate-200 shadow-sm hover:border-slate-300 hover:bg-slate-50 text-slate-600 hover:text-slate-900'"
                                @@click="categoriaSeleccionada = 'all'">
                            <i data-lucide="layout-grid" class="w-3.5 h-3.5"></i>
                            Ver Todo
                        </button>
                        <template x-for="cat in categorias" :key="cat">
                            <button class="px-6 py-2.5 rounded-full text-xs font-black whitespace-nowrap capitalize transition-all duration-300 flex items-center gap-1.5"
                                    :class="categoriaSeleccionada === cat 
                                        ? 'bg-slate-900 text-white shadow-xl shadow-slate-900/20 scale-100' 
                                        : 'bg-white border border-slate-200 shadow-sm hover:border-slate-300 hover:bg-slate-50 text-slate-600 hover:text-slate-900'"
                                    @@click="categoriaSeleccionada = cat">
                                <span x-text="cat"></span>
                            </button>
                        </template>
                    </div>
                </div>

                <!-- Skeletons de Carga -->
                <div x-show="isLoading" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 mb-12">
                    @for (int i = 0; i < 8; i++)
                    {
                        <div class="bg-white border border-slate-100 rounded-[28px] overflow-hidden shadow-sm flex flex-col justify-between h-[360px]">
                            <div class="w-full h-48 bg-slate-100 animate-pulse"></div>
                            <div class="p-5 flex-grow flex flex-col gap-3">
                                <div class="w-2/3 h-5 bg-slate-100 rounded-md animate-pulse"></div>
                                <div class="w-full h-3 bg-slate-50 rounded-md animate-pulse mt-2"></div>
                                <div class="w-4/5 h-3 bg-slate-50 rounded-md animate-pulse"></div>
                                <div class="mt-auto pt-4 flex items-center justify-between">
                                    <div class="w-1/3 h-6 bg-slate-100 rounded-md animate-pulse"></div>
                                    <div class="w-10 h-10 bg-slate-100 rounded-full animate-pulse"></div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Carruseles Destacados (Ocultos en estado de búsqueda o filtrado) -->
                <div x-show="!isLoading && searchQuery === '' && categoriaSeleccionada === 'all'" class="space-y-10 mb-12" x-cloak>
                    <!-- Ofertas del Día -->
                    <template x-if="dailyOffers().length > 0">
                        <section>
                            <div class="flex items-center justify-between mb-4">
                                <h2 class="text-xl font-black text-slate-900 flex items-center gap-2">
                                    <span class="p-1.5 rounded-lg bg-rose-500/10 text-rose-500"><i data-lucide="flame" class="w-5 h-5"></i></span>
                                    Ofertas Flash
                                </h2>
                            </div>
                            <div class="flex overflow-x-auto gap-4 pb-4 snap-x snap-mandatory scrollbar-none" style="-webkit-overflow-scrolling: touch;">
                                <template x-for="prod in dailyOffers()" :key="'offer-' + prod.id">
                                    <!-- Tarjeta Mini -->
                                    <div class="flex-none w-[260px] snap-start group bg-white border border-rose-100 hover:border-rose-200 rounded-[24px] overflow-hidden shadow-sm hover:shadow-xl hover:shadow-rose-500/10 hover:-translate-y-1 transition-all duration-300 relative product-card-wrapper">
                                        <a :href="'/producto/' + prod.tokenPublico" class="block relative h-40 bg-slate-50 overflow-hidden">
                                            <template x-if="prod.fotoUrl">
                                                <img :src="prod.fotoUrl" :alt="prod.nombre" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                                            </template>
                                            <template x-if="!prod.fotoUrl">
                                                <div class="w-full h-full flex items-center justify-center bg-rose-50 text-rose-200">
                                                    <i data-lucide="shopping-bag" class="w-10 h-10"></i>
                                                </div>
                                            </template>
                                            <div class="absolute top-3 left-3 bg-rose-500 text-white text-[9px] font-black uppercase tracking-wider px-2.5 py-1 rounded-full shadow-sm">Oferta</div>
                                        </a>
                                        <div class="p-4">
                                            <h3 class="text-sm font-bold text-slate-900 line-clamp-1" x-text="prod.nombre"></h3>
                                            <div class="mt-2 flex items-center justify-between">
                                                <div class="flex flex-col">
                                                    <span class="text-[10px] text-slate-400 line-through" x-text="prod.precioAnterior ? (prod.moneda + ' ' + parseFloat(prod.precioAnterior).toFixed(2)) : ''"></span>
                                                    <span class="text-base font-black text-rose-600" x-text="prod.precio ? (prod.moneda + ' ' + parseFloat(prod.precio).toFixed(2)) : 'Consultar'"></span>
                                                </div>
                                                <button @@click.prevent="animateToCart($event, prod)" class="w-8 h-8 rounded-full bg-rose-50 hover:bg-rose-500 text-rose-500 hover:text-white flex items-center justify-center transition-colors">
                                                    <i data-lucide="plus" class="w-4 h-4"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </template>
                            </div>
                        </section>
                    </template>

                    <!-- Lo Más Vendido -->
                    <template x-if="bestSellers().length > 0">
                        <section>
                            <div class="flex items-center justify-between mb-4">
                                <h2 class="text-xl font-black text-slate-900 flex items-center gap-2">
                                    <span class="p-1.5 rounded-lg bg-amber-500/10 text-amber-500"><i data-lucide="star" class="w-5 h-5"></i></span>
                                    Lo Más Vendido
                                </h2>
                            </div>
                            <div class="flex overflow-x-auto gap-4 pb-4 snap-x snap-mandatory scrollbar-none" style="-webkit-overflow-scrolling: touch;">
                                <template x-for="prod in bestSellers()" :key="'best-' + prod.id">
                                    <div class="flex-none w-[260px] snap-start group bg-white border border-slate-100 hover:border-amber-200 rounded-[24px] overflow-hidden shadow-sm hover:shadow-xl hover:shadow-amber-500/10 hover:-translate-y-1 transition-all duration-300 relative product-card-wrapper">
                                        <a :href="'/producto/' + prod.tokenPublico" class="block relative h-32 bg-slate-50 overflow-hidden">
                                            <template x-if="prod.fotoUrl">
                                                <img :src="prod.fotoUrl" :alt="prod.nombre" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                                            </template>
                                            <template x-if="!prod.fotoUrl">
                                                <div class="w-full h-full flex items-center justify-center bg-amber-50 text-amber-200">
                                                    <i data-lucide="shopping-bag" class="w-10 h-10"></i>
                                                </div>
                                            </template>
                                        </a>
                                        <div class="p-4">
                                            <h3 class="text-sm font-bold text-slate-900 line-clamp-1" x-text="prod.nombre"></h3>
                                            <div class="mt-2 flex items-center justify-between">
                                                <span class="text-base font-black text-slate-900" x-text="prod.precio ? (prod.moneda + ' ' + parseFloat(prod.precio).toFixed(2)) : 'Consultar'"></span>
                                                <button @@click.prevent="animateToCart($event, prod)" class="w-8 h-8 rounded-full bg-slate-50 hover:bg-brand-500 text-slate-400 hover:text-white flex items-center justify-center transition-colors">
                                                    <i data-lucide="plus" class="w-4 h-4"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </template>
                            </div>
                        </section>
                    </template>
                </div>

                <!-- Grid de Productos -->
                <div x-show="!isLoading" x-transition.opacity class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
                    <template x-for="prod in filteredProducts()" :key="prod.id">
                        <div class="product-card-wrapper group bg-slate-50/50 hover:bg-white border border-slate-100 hover:border-slate-200/60 rounded-[28px] overflow-hidden shadow-sm hover:shadow-2xl hover:shadow-slate-200/50 hover:-translate-y-1.5 transition-all duration-500 flex flex-col justify-between relative">
                            
                            <!-- Wrapper Link al Detalle del Producto -->
                            <a :href="'/producto/' + prod.tokenPublico" class="block cursor-pointer flex-grow">
                                <!-- Imagen Contenedor -->
                                <div class="relative aspect-square w-full overflow-hidden bg-slate-100/50 flex items-center justify-center">
                                    <template x-if="prod.enOferta">
                                        <span class="absolute top-3.5 left-3.5 bg-red-500/10 text-red-650 border border-red-500/20 text-[9px] font-black uppercase px-2.5 py-1 rounded-xl z-10 tracking-wider backdrop-blur-md">
                                            Oferta
                                        </span>
                                    </template>
                                    
                                    <template x-if="prod.fotoUrl">
                                        <img :src="prod.fotoUrl" :alt="prod.nombre" class="w-full h-full object-cover scale-100 group-hover:scale-[1.04] transition-all duration-700 ease-out" />
                                    </template>
                                    <template x-if="!prod.fotoUrl">
                                        <div class="w-full h-full flex flex-col items-center justify-center bg-gradient-to-br from-slate-50 to-slate-100 text-slate-300">
                                            <div class="p-4 bg-white rounded-full shadow-sm mb-2 border border-slate-100">
                                                <i data-lucide="package" class="w-8 h-8 text-slate-300"></i>
                                            </div>
                                        </div>
                                    </template>
                                    <div class="absolute inset-0 bg-slate-950/0 group-hover:bg-slate-950/[0.02] transition-colors duration-500"></div>
                                </div>

                                <!-- Detalles del Producto -->
                                <div class="p-5 space-y-1">
                                    <h4 class="font-extrabold text-slate-900 text-sm sm:text-base tracking-tight group-hover:text-slate-800 transition-colors duration-300 line-clamp-1" x-text="prod.nombre"></h4>
                                    <p class="text-slate-400 text-xs font-medium line-clamp-2 h-8 leading-relaxed" x-text="prod.descripcion || 'Sin descripción disponible.'"></p>
                                </div>
                            </a>

                            <!-- Fila de Precios y Agregar -->
                            <div class="p-5 pt-0 flex items-center justify-between gap-4 mt-auto">
                                <div>
                                    <template x-if="prod.enOferta && prod.precioAnterior">
                                        <div class="flex flex-col">
                                            <span class="text-slate-400 line-through text-[10px] font-bold" x-text="prod.precioAnterior ? `${prod.moneda} ${parseFloat(prod.precioAnterior).toFixed(2)}` : ''"></span>
                                            <span class="text-brand-650 font-black text-sm sm:text-base" x-text="prod.precio ? `${prod.moneda} ${parseFloat(prod.precio).toFixed(2)}` : 'Consultar'"></span>
                                        </div>
                                    </template>
                                    <template x-if="!(prod.enOferta && prod.precioAnterior)">
                                        <span class="text-brand-650 font-black text-sm sm:text-base" x-text="prod.precio ? `${prod.moneda} ${parseFloat(prod.precio).toFixed(2)}` : 'Consultar'"></span>
                                    </template>
                                </div>

                                <button class="w-10 h-10 rounded-full bg-white border border-slate-200 hover:border-brand-500 hover:bg-brand-500 hover:text-white flex items-center justify-center text-slate-400 transition-all duration-300 shadow-sm"
                                        @@click.prevent="animateToCart($event, prod)">
                                    <i data-lucide="plus" class="w-4.5 h-4.5"></i>
                                </button>
                            </div>
                        </div>
                    </template>

                    <!-- Estado Vacío -->
                    <div class="col-span-full py-20 text-center" x-show="filteredProducts().length === 0" x-cloak>
                        <div class="inline-flex p-4 bg-slate-50 text-slate-400 rounded-full mb-4 border border-slate-100">
                            <i data-lucide="search" class="w-7 h-7"></i>
                        </div>
                        <h4 class="text-lg font-bold text-slate-800">No se encontraron productos</h4>
                        <p class="text-slate-500 text-sm mt-1">Intenta realizar otra búsqueda o cambia de categoría.</p>
                    </div>
                </div>
            </div>

            <!-- Sección de Contacto e Info (Estilo Landing Page Cowib) -->
            <section id="contacto" class="bg-slate-50/50 border-t border-slate-100 py-20">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="text-center max-w-2xl mx-auto mb-16">
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold bg-brand-50 text-brand-600 border border-brand-100 uppercase tracking-wider mb-3">
                            Contacto Directo
                        </span>
                        <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight">Estamos para Ayudarte</h2>
                        <p class="text-slate-500 text-sm mt-3">¿Tienes alguna duda o quieres hacer un pedido especial? Ponte en contacto con nosotros directamente.</p>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
                        <!-- Tarjeta Izquierda (Canales de Comunicación) -->
                        <div class="bg-white border border-slate-200/60 rounded-3xl p-8 sm:p-10 shadow-xl shadow-slate-100/50 flex flex-col justify-between space-y-8">
                            <div>
                                <h3 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
                                    <span class="w-2.5 h-2.5 rounded-full bg-brand-500"></span>
                                    Canales de Comunicación
                                </h3>
                                
                                <div class="space-y-6">
                                    <!-- Dirección -->
                                    <div class="flex items-start gap-4">
                                        <div class="p-3 bg-slate-50 text-slate-400 rounded-2xl flex-shrink-0">
                                            <i data-lucide="map-pin" class="w-5 h-5 text-slate-600"></i>
                                        </div>
                                        <div>
                                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Dirección de la Tienda</p>
                                            <p class="text-sm font-semibold text-slate-750 mt-0.5">@tienda.Direccion, @tienda.Ciudad, @tienda.Departamento</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Botones Interactivos Premium -->
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4">
                                @if (!string.IsNullOrEmpty(tienda.WhatsApp))
                                {
                                    var whatsappLink = BuscaYa.Utils.WhatsAppHelper.GenerarLinkSimple(tienda.WhatsApp);
                                    <a href="@whatsappLink" target="_blank" 
                                       class="flex items-center justify-center gap-2.5 px-6 py-4 bg-[#25D366] hover:bg-[#20ba59] active:scale-[0.98] transition-all text-white font-extrabold rounded-2xl shadow-lg shadow-emerald-500/10 text-sm">
                                        <svg class="w-5 h-5 fill-current" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
                                        </svg>
                                        WhatsApp
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(tienda.Telefono))
                                {
                                    <a href="tel:@tienda.Telefono" 
                                       class="flex items-center justify-center gap-2.5 px-6 py-4 bg-brand-500 hover:bg-brand-600 active:scale-[0.98] transition-all text-white font-extrabold rounded-2xl shadow-lg shadow-brand-500/20 text-sm">
                                        <i data-lucide="phone" class="w-5 h-5 text-white"></i>
                                        Llamar al Comercio
                                    </a>
                                }
                            </div>
                        </div>

                        <!-- Tarjeta Derecha (Horarios de Atención) -->
                        <div class="bg-white border border-slate-200/60 rounded-3xl p-8 sm:p-10 shadow-xl shadow-slate-100/50 flex flex-col justify-between space-y-8">
                            <div>
                                <div class="flex items-center justify-between mb-6">
                                    <h3 class="text-xl font-bold text-slate-900 flex items-center gap-2">
                                        <i data-lucide="clock" class="w-5 h-5 text-slate-500"></i>
                                        Horarios de Atención
                                    </h3>
                                    @if (tienda.EstaAbierta)
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold bg-emerald-500/10 text-emerald-650 border border-emerald-500/20">
                                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                                            Abierto Hoy
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold bg-red-500/10 text-red-650 border border-red-500/20">
                                            <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                                            Cerrado
                                        </span>
                                    }
                                </div>

                                <div class="divide-y divide-slate-100 text-sm text-slate-650">
                                    <div class="flex justify-between py-4">
                                        <span class="font-medium text-slate-500">Días de Atención:</span>
                                        <span class="font-semibold text-slate-850">@(tienda.DiasAtencion ?? "No especificado")</span>
                                    </div>
                                    <div class="flex justify-between py-4">
                                        <span class="font-medium text-slate-500">Hora de Apertura:</span>
                                        <span class="font-semibold text-slate-850">@(tienda.HorarioApertura.HasValue ? tienda.HorarioApertura.Value.ToString(@"hh\:mm") : "No especificado")</span>
                                    </div>
                                    <div class="flex justify-between py-4">
                                        <span class="font-medium text-slate-500">Hora de Cierre:</span>
                                        <span class="font-semibold text-slate-850">@(tienda.HorarioCierre.HasValue ? tienda.HorarioCierre.Value.ToString(@"hh\:mm") : "No especificado")</span>
                                    </div>
                                </div>
                            </div>

                            <p class="text-xs text-slate-400 text-center italic">
                                * Los horarios pueden variar en días festivos nacionales.
                            </p>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <!-- Footer Completo Premium (Estilo Cowib) -->
        <footer class="bg-gradient-to-b from-slate-900 to-slate-950 text-slate-400 pt-16 pb-12 border-t border-slate-800/85 relative overflow-hidden">
            <!-- Capa decorativa de iluminación sutil de fondo -->
            <div class="absolute top-0 left-1/4 -translate-y-1/2 w-[500px] h-[250px] bg-brand-500/5 rounded-full blur-[120px] pointer-events-none"></div>

            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8 pb-12 border-b border-slate-800/60">
                    
                    <!-- Info de la Marca (5 cols) -->
                    <div class="md:col-span-5 space-y-5">
                        <div class="flex items-center gap-3 text-white group cursor-default">
                            <img src="/images/app_launcher_icon.png" alt="BuscaYa Icon" class="w-9 h-9 rounded-xl object-cover shadow-sm border border-slate-800 transition-transform group-hover:scale-105 duration-300" />
                            <div class="flex flex-col">
                                <span class="font-extrabold text-xl tracking-tight leading-none">BuscaYa</span>
                                <span class="text-[9px] text-brand-400 font-bold uppercase tracking-widest mt-1">El comercio en tus manos</span>
                            </div>
                        </div>
                        <p class="text-xs text-slate-400 leading-relaxed max-w-sm">
                            Transformamos el comercio local en Nicaragua con catálogos digitales interactivos y autogestionables de alta velocidad.
                        </p>
                        <!-- Redes Sociales -->
                        <div class="flex items-center gap-3 pt-2">
                            <a href="https://wa.me/50587788487" target="_blank" class="w-8 h-8 rounded-xl bg-slate-800 hover:bg-emerald-600 text-slate-350 hover:text-white flex items-center justify-center transition-all duration-300 shadow-sm" aria-label="WhatsApp">
                                <i data-lucide="phone-call" class="w-4 h-4"></i>
                            </a>
                            <a href="https://facebook.com/buscaya" target="_blank" class="w-8 h-8 rounded-xl bg-slate-800 hover:bg-blue-600 text-slate-350 hover:text-white flex items-center justify-center transition-all duration-300 shadow-sm" aria-label="Facebook">
                                <i data-lucide="facebook" class="w-4 h-4"></i>
                            </a>
                            <a href="https://instagram.com/buscaya" target="_blank" class="w-8 h-8 rounded-xl bg-slate-800 hover:bg-pink-600 text-slate-350 hover:text-white flex items-center justify-center transition-all duration-300 shadow-sm" aria-label="Instagram">
                                <i data-lucide="instagram" class="w-4 h-4"></i>
                            </a>
                            <a href="https://buscaya.encuentrame.org" class="w-8 h-8 rounded-xl bg-slate-800 hover:bg-brand-500 text-slate-350 hover:text-white flex items-center justify-center transition-all duration-300 shadow-sm" aria-label="Sitio Web">
                                <i data-lucide="globe" class="w-4 h-4"></i>
                            </a>
                        </div>
                    </div>

                    <!-- Enlaces Rápidos (2 cols) -->
                    <div class="md:col-span-2 space-y-4">
                        <h4 class="text-xs font-bold text-white uppercase tracking-wider">Catálogo</h4>
                        <ul class="space-y-3 text-xs">
                            <li>
                                <a href="#catalogo" class="text-slate-400 hover:text-brand-400 transition-all duration-200 flex items-center gap-2 group">
                                    <span class="w-1 h-1 rounded-full bg-slate-700 group-hover:bg-brand-400 transition-colors"></span>
                                    <span>Productos</span>
                                </a>
                            </li>
                            <li>
                                <a href="#contacto" class="text-slate-400 hover:text-brand-400 transition-all duration-200 flex items-center gap-2 group">
                                    <span class="w-1 h-1 rounded-full bg-slate-700 group-hover:bg-brand-400 transition-colors"></span>
                                    <span>Contacto</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Soporte y Legal (2 cols) -->
                    <div class="md:col-span-2 space-y-4">
                        <h4 class="text-xs font-bold text-white uppercase tracking-wider">Legal</h4>
                        <ul class="space-y-3 text-xs">
                            <li>
                                <a href="https://www.cowib.es/terminos" target="_blank" class="text-slate-400 hover:text-brand-400 transition-all duration-200 flex items-center gap-2 group">
                                    <span class="w-1 h-1 rounded-full bg-slate-700 group-hover:bg-brand-400 transition-colors"></span>
                                    <span>Términos</span>
                                </a>
                            </li>
                            <li>
                                <a href="https://www.cowib.es/privacidad" target="_blank" class="text-slate-400 hover:text-brand-400 transition-all duration-200 flex items-center gap-2 group">
                                    <span class="w-1 h-1 rounded-full bg-slate-700 group-hover:bg-brand-400 transition-colors"></span>
                                    <span>Privacidad</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Descarga directa (3 cols) -->
                    <div class="md:col-span-3 space-y-4">
                        <h4 class="text-xs font-bold text-white uppercase tracking-wider">Nuestra App</h4>
                        <p class="text-xs text-slate-400 leading-relaxed">
                            Lleva el comercio en tu bolsillo descargando la app de BuscaYa.
                        </p>
                        <div class="flex flex-row md:flex-col gap-2.5 pt-1">
                            <a href="https://play.google.com/store/apps/details?id=com.buscaya.app" target="_blank" class="h-9 hover:-translate-y-0.5 transition-transform duration-200">
                                <img src="https://upload.wikimedia.org/wikipedia/commons/7/78/Google_Play_Store_badge_EN.svg" alt="Google Play" class="h-full object-contain" />
                            </a>
                            <a href="https://apps.apple.com/app/id6762116740" target="_blank" class="h-9 hover:-translate-y-0.5 transition-transform duration-200">
                                <img src="https://upload.wikimedia.org/wikipedia/commons/3/3c/Download_on_the_App_Store_Badge.svg" alt="App Store" class="h-full object-contain" />
                            </a>
                        </div>
                    </div>

                </div>

                <!-- Fila Copyright -->
                <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-[11px] text-slate-500">
                    <p>© @DateTime.Now.Year BuscaYa. Todos los derechos reservados. Nicaragua.</p>
                    <div class="flex items-center gap-4">
                        <span class="flex items-center gap-1.5">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                            <span>Sistema Activo</span>
                        </span>
                        <span>v2.5.0</span>
                    </div>
                </div>
            </div>
        </footer>

        <!-- Carrito de Compras Flotante (Rediseño Circular Elegante) -->
        <div class="fixed bottom-6 right-6 z-40" x-show="cart.length > 0" x-transition x-cloak>
            <button class="relative flex items-center justify-center w-14 h-14 bg-brand-500 hover:bg-brand-600 text-white rounded-full shadow-2xl hover:scale-105 active:scale-95 transition-all shadow-brand-500/20"
                    @@click="cartOpen = true">
                <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                <span class="absolute -top-1 -right-1 bg-red-500 text-white font-extrabold text-[10px] w-5 h-5 rounded-full flex items-center justify-center shadow"
                      x-text="cartTotalCount()"></span>
            </button>
        </div>

        <!-- Sidebar del Carrito (Slide Over Moderno) -->
        <div class="fixed inset-0 z-50 overflow-hidden" 
             x-show="cartOpen" 
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-200"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             x-cloak>
            
            <!-- Backdrop -->
            <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" @@click="cartOpen = false"></div>

            <div class="absolute inset-y-0 right-0 max-w-full flex">
                <div class="w-screen max-w-md bg-white border-l border-slate-100 flex flex-col"
                     x-show="cartOpen"
                     x-transition:enter="transform transition ease-out duration-300"
                     x-transition:enter-start="translate-x-full"
                     x-transition:enter-end="translate-x-0"
                     x-transition:leave="transform transition ease-in duration-200"
                     x-transition:leave-start="translate-x-0"
                     x-transition:leave-end="translate-x-full">
                    
                    <!-- Header -->
                    <div class="p-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                        <div class="flex items-center gap-2">
                            <i data-lucide="shopping-bag" class="w-5 h-5 text-brand-500"></i>
                            <h3 class="text-base font-bold text-slate-900">Detalle de tu Pedido</h3>
                        </div>
                        <button class="p-2 hover:bg-slate-100 rounded-lg text-slate-400 hover:text-slate-750 transition"
                                @@click="cartOpen = false">
                            <i data-lucide="x" class="w-5 h-5"></i>
                        </button>
                    </div>

                    <!-- Items del carrito -->
                    <div class="flex-1 overflow-y-auto p-6 space-y-4">
                        <template x-for="item in cart" :key="item.id">
                            <div class="flex items-center gap-4 bg-slate-50/50 p-4 rounded-2xl border border-slate-100">
                                <!-- Mini Foto -->
                                <div class="w-14 h-14 rounded-xl bg-slate-100 overflow-hidden flex-shrink-0 flex items-center justify-center border border-slate-200">
                                    <template x-if="item.fotoUrl">
                                        <img :src="item.fotoUrl" class="w-full h-full object-cover" />
                                    </template>
                                    <template x-if="!item.fotoUrl">
                                        <div class="w-full h-full flex flex-col items-center justify-center bg-gradient-to-br from-slate-50 to-slate-100 border-r border-slate-100">
                                            <i data-lucide="package" class="w-5 h-5 text-slate-300"></i>
                                        </div>
                                    </template>
                                </div>

                                <!-- Detalles del Producto -->
                                <div class="flex-1 min-w-0">
                                    <h4 class="text-sm font-semibold text-slate-900 truncate" x-text="item.nombre"></h4>
                                    <p class="text-xs text-brand-500 font-bold mt-0.5" x-text="`${item.moneda} ${parseFloat(item.precio).toFixed(2)}`"></p>
                                </div>

                                <!-- Controles de Cantidad -->
                                <div class="flex items-center bg-white border border-slate-200 rounded-xl px-2 py-1">
                                    <button class="p-1 text-slate-400 hover:text-brand-500 transition" @@click="updateQuantity(item.id, -1)">
                                        <i data-lucide="minus" class="w-3.5 h-3.5"></i>
                                    </button>
                                    <span class="px-2 text-xs font-bold text-slate-900" x-text="item.qty"></span>
                                    <button class="p-1 text-slate-400 hover:text-brand-500 transition" @@click="updateQuantity(item.id, 1)">
                                        <i data-lucide="plus" class="w-3.5 h-3.5"></i>
                                    </button>
                                </div>
                            </div>
                        </template>

                        <div class="text-center py-12 text-slate-400" x-show="cart.length === 0">
                            <i data-lucide="shopping-basket" class="w-12 h-12 mx-auto text-slate-300 mb-3"></i>
                            <p class="text-sm">Tu pedido está vacío.</p>
                        </div>
                    </div>

                    <!-- Checkout Box -->
                    <div class="p-6 border-t border-slate-100 bg-slate-50/50 space-y-4">
                        <div class="flex items-center justify-between text-slate-500 text-sm">
                            <span>Artículos:</span>
                            <span class="text-slate-900 font-bold" x-text="cartTotalCount()"></span>
                        </div>
                        <div class="flex items-center justify-between text-base">
                            <span class="text-slate-700 font-semibold">Total estimado:</span>
                            <span class="text-brand-500 font-extrabold text-xl" x-text="`${cartCurrency()} ${cartTotalAmount().toFixed(2)}`"></span>
                        </div>

                        <!-- Dirección de entrega -->
                        <div class="space-y-1.5 pt-2">
                            <label class="text-[10px] font-bold text-slate-450 uppercase tracking-wider">Dirección de Entrega</label>
                            <textarea placeholder="Ingresa tu dirección exacta..." 
                                      x-model="deliveryAddress"
                                      class="w-full p-3 bg-white border border-slate-200 focus:border-brand-500 rounded-xl text-xs text-slate-900 placeholder-slate-400 outline-none resize-none h-16 transition-all"></textarea>
                        </div>

                        <!-- Botón WhatsApp Checkout -->
                        <button class="w-full py-4 bg-emerald-600 hover:bg-emerald-500 active:scale-[0.98] transition-all text-white font-bold rounded-2xl flex items-center justify-center gap-3 shadow-md shadow-emerald-650/10"
                                :disabled="cart.length === 0"
                                @@click="sendOrderWhatsApp()">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
                                <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
                            </svg>
                            Enviar Pedido por WhatsApp
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Botón Volver Arriba Flotante -->
    <button x-data="{ show: false }" 
            @@scroll.window="show = window.pageYOffset > 500"
            x-show="show"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 translate-y-10"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-300"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 translate-y-10"
            @@click="window.scrollTo({ top: 0, behavior: 'smooth' })"
            class="fixed bottom-32 right-6 md:bottom-8 md:right-8 z-40 bg-slate-900 text-white p-3.5 rounded-full shadow-2xl hover:bg-brand-500 hover:scale-110 active:scale-95 transition-all flex items-center justify-center ring-4 ring-slate-900/10"
            style="display: none;"
            aria-label="Volver arriba">
        <i data-lucide="arrow-up" class="w-5 h-5"></i>
    </button>

    <!-- Script de Inicialización de Alpine.js para la lógica del Catálogo -->
    <script src="~/js/public/tienda.js?v=@(DateTime.Now.Ticks)"></script>
    <script>
        const tiendaConfig = {
            whatsappNum: '@tienda?.WhatsApp',
            storeName: @Html.Raw(Json.Serialize(tienda?.Nombre ?? "")),
            storeId: '@tienda?.Id',
            products: @Html.Raw(Json.Serialize(tienda?.Productos ?? new List<ProductoSimpleResponse>()))
        };
    </script>
</body>
</html>
