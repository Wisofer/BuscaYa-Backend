@using BuscaYa.Models.DTOs.Responses
@{
    var tienda = ViewData["Tienda"] as TiendaResponse;
    var deepLink = ViewData["DeepLink"] as string ?? "";
    var appleAppId = ViewData["AppleAppId"] as string;

    ViewData["Title"] = tienda?.Nombre ?? "Tienda";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@tienda?.Nombre - Catálogo Digital | BuscaYa</title>

    <!-- Meta tags para compartir en redes sociales -->
    <meta property="og:title" content="@tienda?.Nombre - Catálogo Digital en BuscaYa" />
    <meta property="og:description" content="@(tienda?.Descripcion ?? "Explora nuestro catálogo en línea y haz tus pedidos directamente por WhatsApp.")" />
    @if (!string.IsNullOrEmpty(tienda?.FotoUrl ?? tienda?.LogoUrl))
    {
        <meta property="og:image" content="@(tienda?.FotoUrl ?? tienda?.LogoUrl)" />
    }
    <meta property="og:type" content="business.business" />
    @if (!string.IsNullOrEmpty(appleAppId))
    {
        <meta name="apple-itunes-app" content="app-id=@appleAppId" />
    }

    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <!-- Alpine.js & Tailwind CSS -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#f0f7ff',
                            100: '#e0effe',
                            500: '#1d4ed8', // Azul real premium
                            600: '#1e40af', // Azul oscuro
                            700: '#1d3557',
                            900: '#0f172a',
                        },
                    }
                }
            }
        }
    </script>

    <style>
        [x-cloak] { display: none !important; }
        
        body {
            background-color: #fcfcfd;
            color: #1e293b;
        }

        /* Ocultar barra de scroll nativa */
        .scrollbar-none::-webkit-scrollbar {
            display: none;
        }
        .scrollbar-none {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>
<body class="antialiased selection:bg-brand-500 selection:text-white" 
      x-data="catalogoStore({ 
          whatsappNum: '@tienda?.WhatsApp', 
          storeName: '@tienda?.Nombre', 
          storeId: '@tienda?.Id' 
      })">

    @if (tienda == null)
    {
        <!-- Vista Tienda No Encontrada -->
        <div class="min-h-screen flex items-center justify-center px-4">
            <div class="max-w-md w-full text-center bg-white border border-slate-100 p-8 rounded-3xl shadow-xl">
                <div class="inline-flex p-4 bg-red-50 text-red-500 rounded-2xl mb-6">
                    <i data-lucide="store" class="w-12 h-12"></i>
                </div>
                <h2 class="text-2xl font-bold text-slate-900 mb-2">Comercio no encontrado</h2>
                <p class="text-slate-500 mb-6">El comercio que intentas buscar no está disponible o la dirección es incorrecta.</p>
                <a href="https://buscaya.encuentrame.org" class="inline-flex items-center gap-2 px-6 py-3 bg-brand-500 hover:bg-brand-600 active:scale-95 transition-all text-white font-semibold rounded-xl">
                    <i data-lucide="arrow-left" class="w-5 h-5"></i>
                    Ir a BuscaYa
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Banner Inteligente (Descargar App - Ultra-premium) -->
        <div class="bg-white/80 border-b border-slate-100 text-slate-750 text-xs py-3 px-4 sticky top-0 z-50 backdrop-blur-md shadow-sm">
            <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-brand-500 to-blue-600 flex items-center justify-center shadow-sm text-white font-extrabold text-sm">
                        B
                    </div>
                    <div>
                        <p class="font-bold text-slate-900 text-xs">Descargar BuscaYa App</p>
                        <p class="text-[10px] text-slate-500">Guarda tus comercios favoritos y recibe ofertas exclusivas</p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <a href="@deepLink" class="px-3 py-1.5 bg-slate-100 hover:bg-slate-200 active:scale-95 transition text-slate-700 font-semibold rounded-lg text-xs">
                        Abrir
                    </a>
                    <a href="/descargar" class="px-3 py-1.5 bg-brand-500 hover:bg-brand-600 active:scale-95 transition text-white font-semibold rounded-lg text-xs shadow-sm shadow-brand-500/10">
                        Descargar
                    </a>
                </div>
            </div>
        </div>

        <div class="min-h-screen pb-24">
            <!-- Portada de la Tienda (Sin bordes duros) -->
            <div class="relative h-48 sm:h-64 md:h-80 w-full overflow-hidden bg-slate-100">
                <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-transparent to-black/35 z-10"></div>
                @if (!string.IsNullOrEmpty(tienda.FotoUrl))
                {
                    <img src="@tienda.FotoUrl" alt="@tienda.Nombre" class="w-full h-full object-cover scale-100" />
                }
                else
                {
                    <div class="w-full h-full bg-gradient-to-tr from-slate-100 to-slate-200"></div>
                }
            </div>

            <!-- Contenedor Principal (Estilo Perfil Editorial e Integrado) -->
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-20 -mt-16 sm:-mt-20">
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 pb-6 border-b border-slate-100">
                    <div class="flex flex-col sm:flex-row items-start sm:items-end gap-4 sm:gap-6">
                        <!-- Logo Circular Flotante (Solapado) -->
                        <div class="w-28 h-28 sm:w-36 sm:h-36 rounded-full border-4 border-white overflow-hidden bg-white shadow-xl flex-shrink-0 flex items-center justify-center relative z-30">
                            @if (!string.IsNullOrEmpty(tienda.LogoUrl))
                            {
                                <img src="@tienda.LogoUrl" alt="Logo de @tienda.Nombre" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <span class="text-4xl font-extrabold text-brand-500">@tienda.Nombre.Substring(0, 1).ToUpper()</span>
                            }
                        </div>

                        <!-- Información Textual -->
                        <div class="space-y-2.5">
                            <div class="flex flex-wrap items-center gap-3">
                                <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight flex items-center gap-2">
                                    @tienda.Nombre
                                    <i data-lucide="badge-check" class="w-7 h-7 text-brand-500 fill-brand-500/10"></i>
                                </h1>
                                
                                @if (tienda.EstaAbierta)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold bg-emerald-50 text-emerald-600 border border-emerald-100">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                                        Abierto
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold bg-red-50 text-red-500 border border-red-100">
                                        <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                                        Cerrado
                                    </span>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(tienda.Descripcion))
                            {
                                <p class="text-slate-600 text-sm sm:text-base max-w-2xl font-normal leading-relaxed">@tienda.Descripcion</p>
                            }

                            <!-- Ubicación, Distancia y Horarios -->
                            <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-xs sm:text-sm text-slate-500">
                                @if (!string.IsNullOrEmpty(tienda.DireccionCompleta))
                                {
                                    <div class="flex items-center gap-1.5">
                                        <i data-lucide="map-pin" class="w-4 h-4 text-slate-400"></i>
                                        <span>@tienda.DireccionCompleta</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(tienda.HorarioFormateado))
                                {
                                    <div class="flex items-center gap-1.5">
                                        <i data-lucide="clock" class="w-4 h-4 text-slate-400"></i>
                                        <span>@tienda.HorarioFormateado</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Botones de Acción (Estilo Limpio e Integrado) -->
                    <div class="flex gap-3 w-full md:w-auto self-stretch md:self-auto flex-wrap sm:flex-nowrap">
                        @if (!string.IsNullOrEmpty(tienda.WhatsApp))
                        {
                            var whatsappLink = BuscaYa.Utils.WhatsAppHelper.GenerarLinkSimple(tienda.WhatsApp);
                            <a href="@whatsappLink" target="_blank" class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2 px-6 py-3 bg-emerald-600 hover:bg-emerald-500 active:scale-95 transition-all text-white font-semibold rounded-2xl shadow-sm text-sm">
                                <i data-lucide="message-square" class="w-4 h-4"></i>
                                WhatsApp
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(tienda.Telefono))
                        {
                            <a href="tel:@tienda.Telefono" class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2 px-6 py-3 bg-white hover:bg-slate-50 active:scale-95 transition-all text-slate-700 font-semibold rounded-2xl border border-slate-200 text-sm shadow-sm">
                                <i data-lucide="phone" class="w-4 h-4"></i>
                                Llamar
                            </a>
                        }
                    </div>
                </div>

                <!-- Buscador y Barra de Categorías (Diseño Horizontal Flotante y Limpio) -->
                <div class="mt-8 space-y-6">
                    <!-- Buscador e input -->
                    <div class="relative max-w-xl">
                        <i data-lucide="search" class="w-5 h-5 text-slate-400 absolute left-4 top-1/2 -translate-y-1/2"></i>
                        <input type="text" 
                               placeholder="Buscar en el catálogo de la tienda..." 
                               x-model="searchQuery"
                               class="w-full pl-12 pr-4 py-3.5 bg-white border border-slate-200 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 rounded-2xl text-slate-900 placeholder-slate-400 outline-none transition-all shadow-sm text-sm" />
                    </div>

                    <!-- Categorías (Navegación horizontal fluida y elegante para todos los dispositivos) -->
                    <div class="border-b border-slate-100 pb-2">
                        <div class="flex overflow-x-auto gap-2 scrollbar-none py-1">
                            <button class="px-5 py-2.5 rounded-full text-xs font-bold whitespace-nowrap transition-all duration-300"
                                    :class="categoriaSeleccionada === 'all' ? 'bg-brand-500 text-white shadow-sm' : 'bg-slate-100/80 text-slate-600 hover:bg-slate-200/60'"
                                    @@click="categoriaSeleccionada = 'all'">
                                Ver Todo
                            </button>
                            <template x-for="cat in categorias" :key="cat">
                                <button class="px-5 py-2.5 rounded-full text-xs font-bold whitespace-nowrap capitalize transition-all duration-300"
                                        :class="categoriaSeleccionada === cat ? 'bg-brand-500 text-white shadow-sm' : 'bg-slate-100/80 text-slate-600 hover:bg-slate-200/60'"
                                        @@click="categoriaSeleccionada = cat"
                                        x-text="cat">
                                </button>
                            </template>
                        </div>
                    </div>
                </div>

                <!-- Catálogo de Productos (Grid elegante de 4 columnas) -->
                <div class="mt-8">
                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
                        <template x-for="prod in filteredProducts()" :key="prod.id">
                            <div class="group bg-white border border-slate-100 hover:border-slate-200 rounded-3xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 flex flex-col justify-between relative">
                                <div>
                                    <!-- Contenedor Imagen con Aspect Ratio Premium -->
                                    <div class="relative aspect-[4/3] w-full overflow-hidden bg-slate-50 flex items-center justify-center">
                                        <!-- Badge de Oferta -->
                                        <template x-if="prod.enOferta">
                                            <span class="absolute top-3 left-3 bg-red-500 text-white text-[10px] font-extrabold uppercase px-2 py-0.5 rounded-lg z-10 tracking-wider shadow">
                                                Oferta
                                            </span>
                                        </template>
                                        
                                        <template x-if="prod.fotoUrl">
                                            <img :src="prod.fotoUrl" :alt="prod.nombre" class="w-full h-full object-cover group-hover:scale-105 transition-all duration-500" />
                                        </template>
                                        <template x-if="!prod.fotoUrl">
                                            <div class="flex flex-col items-center justify-center text-slate-300">
                                                <i data-lucide="image" class="w-10 h-10"></i>
                                            </div>
                                        </template>
                                    </div>

                                    <!-- Detalles del Producto -->
                                    <div class="p-5 space-y-1.5">
                                        <h4 class="font-bold text-slate-800 text-base group-hover:text-brand-500 transition-colors duration-300 line-clamp-1" x-text="prod.nombre"></h4>
                                        <p class="text-slate-500 text-xs line-clamp-2 h-8 leading-relaxed" x-text="prod.descripcion || 'Sin descripción disponible.'"></p>
                                    </div>
                                </div>

                                <!-- Fila Inferior con Precios y Acción -->
                                <div class="p-5 pt-0 flex items-center justify-between gap-4 mt-auto">
                                    <div>
                                        <template x-if="prod.enOferta && prod.precioAnterior">
                                            <div class="flex flex-col">
                                                <span class="text-slate-400 line-through text-xs" x-text="`${prod.moneda} ${parseFloat(prod.precioAnterior).toFixed(2)}`"></span>
                                                <span class="text-brand-500 font-extrabold text-base sm:text-lg" x-text="`${prod.moneda} ${parseFloat(prod.precio).toFixed(2)}`"></span>
                                            </div>
                                        </template>
                                        <template x-if="!(prod.enOferta && prod.precioAnterior)">
                                            <span class="text-brand-500 font-extrabold text-base sm:text-lg" x-text="prod.precio ? `${prod.moneda} ${parseFloat(prod.precio).toFixed(2)}` : 'Consultar'"></span>
                                        </template>
                                    </div>

                                    <!-- Botón Agregar con Icono Elegante -->
                                    <button class="inline-flex items-center gap-1.5 px-3 py-2 bg-brand-500 hover:bg-brand-600 text-white font-bold rounded-xl text-xs transition active:scale-95 shadow-sm shadow-brand-500/10"
                                            @@click="addToCart(prod)">
                                        <i data-lucide="plus" class="w-3.5 h-3.5"></i>
                                        Agregar
                                    </button>
                                </div>
                            </div>
                        </template>

                        <!-- Estado Vacío -->
                        <div class="col-span-full py-20 text-center" x-show="filteredProducts().length === 0" x-cloak>
                            <div class="inline-flex p-4 bg-slate-50 text-slate-400 rounded-full mb-4 border border-slate-100">
                                <i data-lucide="search" class="w-7 h-7"></i>
                            </div>
                            <h4 class="text-lg font-bold text-slate-800">No se encontraron productos</h4>
                            <p class="text-slate-500 text-sm mt-1">Intenta realizar otra búsqueda o cambia de categoría.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer y Descarga de App -->
            <div class="max-w-xl mx-auto px-4 mt-20 text-center">
                <div class="bg-white border border-slate-150 p-8 rounded-3xl shadow-sm">
                    <h3 class="font-bold text-lg text-slate-900 mb-2">¿Quieres ver este negocio en tu celular?</h3>
                    <p class="text-slate-500 text-sm mb-6">Descarga BuscaYa para guardar favoritos, ver horarios actualizados y chatear con comercios de forma nativa.</p>
                    <div class="flex items-center justify-center gap-4 flex-wrap">
                        <a href="https://play.google.com/store/apps/details?id=com.buscaya.app" target="_blank" class="h-10 opacity-90 hover:opacity-100 transition">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/7/78/Google_Play_Store_badge_EN.svg" alt="Google Play" class="h-full object-contain" />
                        </a>
                        <a href="https://apps.apple.com/app/id6762116740" target="_blank" class="h-10 opacity-90 hover:opacity-100 transition">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/3/3c/Download_on_the_App_Store_Badge.svg" alt="App Store" class="h-full object-contain" />
                        </a>
                    </div>
                </div>
                
                <p class="text-slate-400 text-xs mt-10">© @DateTime.Now.Year BuscaYa. Todos los derechos reservados.</p>
            </div>
        </div>

        <!-- Carrito de Compras Flotante (Rediseño Circular Elegante) -->
        <div class="fixed bottom-6 right-6 z-40" x-show="cart.length > 0" x-transition x-cloak>
            <button class="relative flex items-center justify-center w-14 h-14 bg-brand-500 hover:bg-brand-600 text-white rounded-full shadow-2xl hover:scale-105 active:scale-95 transition-all shadow-brand-500/20"
                    @@click="cartOpen = true">
                <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                <span class="absolute -top-1 -right-1 bg-red-500 text-white font-extrabold text-[10px] w-5 h-5 rounded-full flex items-center justify-center shadow"
                      x-text="cartTotalCount()"></span>
            </button>
        </div>

        <!-- Sidebar del Carrito (Slide Over Moderno) -->
        <div class="fixed inset-0 z-50 overflow-hidden" 
             x-show="cartOpen" 
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-200"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             x-cloak>
            
            <!-- Backdrop -->
            <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" @@click="cartOpen = false"></div>

            <div class="absolute inset-y-0 right-0 max-w-full flex">
                <div class="w-screen max-w-md bg-white border-l border-slate-100 flex flex-col"
                     x-show="cartOpen"
                     x-transition:enter="transform transition ease-out duration-300"
                     x-transition:enter-start="translate-x-full"
                     x-transition:enter-end="translate-x-0"
                     x-transition:leave="transform transition ease-in duration-200"
                     x-transition:leave-start="translate-x-0"
                     x-transition:leave-end="translate-x-full">
                    
                    <!-- Header -->
                    <div class="p-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                        <div class="flex items-center gap-2">
                            <i data-lucide="shopping-bag" class="w-5 h-5 text-brand-500"></i>
                            <h3 class="text-base font-bold text-slate-900">Detalle de tu Pedido</h3>
                        </div>
                        <button class="p-2 hover:bg-slate-100 rounded-lg text-slate-400 hover:text-slate-750 transition"
                                @@click="cartOpen = false">
                            <i data-lucide="x" class="w-5 h-5"></i>
                        </button>
                    </div>

                    <!-- Items del carrito -->
                    <div class="flex-1 overflow-y-auto p-6 space-y-4">
                        <template x-for="item in cart" :key="item.id">
                            <div class="flex items-center gap-4 bg-slate-50/50 p-4 rounded-2xl border border-slate-100">
                                <!-- Mini Foto -->
                                <div class="w-14 h-14 rounded-xl bg-slate-100 overflow-hidden flex-shrink-0 flex items-center justify-center border border-slate-200">
                                    <template x-if="item.fotoUrl">
                                        <img :src="item.fotoUrl" class="w-full h-full object-cover" />
                                    </template>
                                    <template x-if="!item.fotoUrl">
                                        <i data-lucide="image" class="w-6 h-6 text-slate-350"></i>
                                    </template>
                                </div>

                                <!-- Detalles del Producto -->
                                <div class="flex-1 min-w-0">
                                    <h4 class="text-sm font-semibold text-slate-900 truncate" x-text="item.nombre"></h4>
                                    <p class="text-xs text-brand-500 font-bold mt-0.5" x-text="`${item.moneda} ${parseFloat(item.precio).toFixed(2)}`"></p>
                                </div>

                                <!-- Controles de Cantidad -->
                                <div class="flex items-center bg-white border border-slate-200 rounded-xl px-2 py-1">
                                    <button class="p-1 text-slate-400 hover:text-brand-500 transition" @@click="updateQuantity(item.id, -1)">
                                        <i data-lucide="minus" class="w-3.5 h-3.5"></i>
                                    </button>
                                    <span class="px-2 text-xs font-bold text-slate-900" x-text="item.qty"></span>
                                    <button class="p-1 text-slate-400 hover:text-brand-500 transition" @@click="updateQuantity(item.id, 1)">
                                        <i data-lucide="plus" class="w-3.5 h-3.5"></i>
                                    </button>
                                </div>
                            </div>
                        </template>

                        <div class="text-center py-12 text-slate-400" x-show="cart.length === 0">
                            <i data-lucide="shopping-basket" class="w-12 h-12 mx-auto text-slate-300 mb-3"></i>
                            <p class="text-sm">Tu pedido está vacío.</p>
                        </div>
                    </div>

                    <!-- Checkout Box -->
                    <div class="p-6 border-t border-slate-100 bg-slate-50/50 space-y-4">
                        <div class="flex items-center justify-between text-slate-555 text-sm">
                            <span>Artículos:</span>
                            <span class="text-slate-900 font-bold" x-text="cartTotalCount()"></span>
                        </div>
                        <div class="flex items-center justify-between text-base">
                            <span class="text-slate-700 font-semibold">Total estimado:</span>
                            <span class="text-brand-500 font-extrabold text-xl" x-text="`${cartCurrency()} ${cartTotalAmount().toFixed(2)}`"></span>
                        </div>

                        <!-- Dirección de entrega -->
                        <div class="space-y-1.5 pt-2">
                            <label class="text-[10px] font-bold text-slate-450 uppercase tracking-wider">Dirección de Entrega</label>
                            <textarea placeholder="Ingresa tu dirección exacta..." 
                                      x-model="deliveryAddress"
                                      class="w-full p-3 bg-white border border-slate-200 focus:border-brand-500 rounded-xl text-xs text-slate-900 placeholder-slate-400 outline-none resize-none h-16 transition-all"></textarea>
                        </div>

                        <!-- Botón WhatsApp Checkout -->
                        <button class="w-full py-4 bg-emerald-600 hover:bg-emerald-500 active:scale-[0.98] transition-all text-white font-bold rounded-2xl flex items-center justify-center gap-3 shadow-md shadow-emerald-650/10"
                                :disabled="cart.length === 0"
                                @@click="sendOrderWhatsApp()">
                            <i data-lucide="message-square" class="w-5 h-5"></i>
                            Enviar Pedido por WhatsApp
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Script de Inicialización de Alpine.js para la lógica del Catálogo -->
    <script>
        function catalogoStore(config) {
            return {
                whatsappNum: config.whatsappNum,
                storeName: config.storeName,
                storeId: config.storeId,
                searchQuery: '',
                categoriaSeleccionada: 'all',
                cartOpen: false,
                deliveryAddress: '',
                cart: [],
                categorias: [],
                
                products: @Html.Raw(Json.Serialize(tienda?.Productos ?? new List<ProductoSimpleResponse>())),

                init() {
                    // Inicializar iconos
                    setTimeout(() => {
                        lucide.createIcons();
                    }, 100);

                    // Extraer categorías reales del negocio
                    const cats = new Set();
                    this.products.forEach(p => {
                        let cat = p.categoriaNombre || "General";
                        p.displayCategory = cat;
                        cats.add(cat);
                    });
                    this.categorias = Array.from(cats);

                    // Cargar carrito de localStorage
                    const savedCart = localStorage.getItem(`buscaya_cart_${this.storeId}`);
                    if (savedCart) {
                        try {
                            this.cart = JSON.parse(savedCart);
                        } catch(e) {
                            this.cart = [];
                        }
                    }

                    // Escuchar cambios de localStorage para auto-guardar
                    this.$watch('cart', value => {
                        localStorage.setItem(`buscaya_cart_${this.storeId}`, JSON.stringify(value));
                        this.$nextTick(() => lucide.createIcons());
                    });
                },

                filteredProducts() {
                    let items = this.products;
                    
                    // Filtrar por categoría
                    if (this.categoriaSeleccionada !== 'all') {
                        items = items.filter(p => p.displayCategory === this.categoriaSeleccionada);
                    }
                    
                    // Filtrar por búsqueda
                    if (this.searchQuery.trim() !== '') {
                        const q = this.searchQuery.toLowerCase();
                        items = items.filter(p => p.nombre.toLowerCase().includes(q) || (p.descripcion && p.descripcion.toLowerCase().includes(q)));
                    }
                    
                    this.$nextTick(() => lucide.createIcons());
                    return items;
                },

                addToCart(product) {
                    const existing = this.cart.find(item => item.id === product.id);
                    if (existing) {
                        existing.qty++;
                    } else {
                        this.cart.push({
                            id: product.id,
                            nombre: product.nombre,
                            precio: product.precio,
                            moneda: product.moneda || 'C$',
                            fotoUrl: product.fotoUrl,
                            qty: 1
                        });
                    }
                    this.cartOpen = true;
                },

                updateQuantity(productId, amount) {
                    const item = this.cart.find(i => i.id === productId);
                    if (item) {
                        item.qty += amount;
                        if (item.qty <= 0) {
                            this.cart = this.cart.filter(i => i.id !== productId);
                        }
                    }
                },

                cartTotalCount() {
                    return this.cart.reduce((sum, item) => sum + item.qty, 0);
                },

                cartTotalAmount() {
                    return this.cart.reduce((sum, item) => sum + (item.precio * item.qty), 0);
                },

                cartCurrency() {
                    return this.cart.length > 0 ? this.cart[0].moneda : 'C$';
                },

                sendOrderWhatsApp() {
                    if (this.cart.length === 0) return;

                    let msg = `*Pedido Nuevo desde tu Catálogo Digital de BuscaYa* 🛍️\n\n`;
                    msg += `*Cliente:* Detalle de Pedido sin registro\n`;
                    if (this.deliveryAddress.trim() !== '') {
                        msg += `*Dirección:* ${this.deliveryAddress.trim()}\n`;
                    }
                    msg += `-------------------------------------------\n`;
                    
                    this.cart.forEach(item => {
                        const itemSub = (item.precio * item.qty).toFixed(2);
                        msg += `• ${item.qty}x *${item.nombre}* (${item.moneda} ${parseFloat(item.precio).toFixed(2)}) -> ${item.moneda} ${itemSub}\n`;
                    });

                    msg += `-------------------------------------------\n`;
                    msg += `*Total a pagar: ${this.cartCurrency()} ${this.cartTotalAmount().toFixed(2)}*\n\n`;
                    msg += `Por favor, confirma mi pedido y el tiempo estimado de entrega. ¡Gracias!`;

                    const cleanPhone = this.whatsappNum.replace(/[^0-9]/g, '');
                    const encodedMsg = encodeURIComponent(msg);
                    const url = `https://wa.me/${cleanPhone}?text=${encodedMsg}`;
                    
                    // Limpiar carrito al ordenar
                    this.cart = [];
                    localStorage.removeItem(`buscaya_cart_${this.storeId}`);
                    this.cartOpen = false;

                    // Abrir WhatsApp
                    window.open(url, '_blank');
                }
            }
        }
    </script>
</body>
</html>
